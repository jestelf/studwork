<beans>
  <bean id="state.CookieProvider" class="jetbrains.mps.webr.javascript.runtime.jsDependencies.JsDependency">
    <property name="name">
      <value>state.CookieProvider</value>
    </property>
    <property name="urlGetter">
      <bean class="jetbrains.mps.webr.javascript.runtime.jsDependencies.ClasspathUrlGetter" autowire="byType">
        <property name="resourcePath">
          <value>state/CookieProvider.js</value>
        </property>
      </bean>
    </property>
    <property name="runTimeDeps">
      <list></list>
    </property>
    <property name="compileTimeDeps">
      <list>
        <value>core.Ext</value>
        <value>state.Provider</value>
        <value>util.Date</value>
      </list>
    </property>
  </bean>
  <bean id="state.Provider" class="jetbrains.mps.webr.javascript.runtime.jsDependencies.JsDependency">
    <property name="name">
      <value>state.Provider</value>
    </property>
    <property name="urlGetter">
      <bean class="jetbrains.mps.webr.javascript.runtime.jsDependencies.ClasspathUrlGetter" autowire="byType">
        <property name="resourcePath">
          <value>state/Provider.js</value>
        </property>
      </bean>
    </property>
    <property name="runTimeDeps">
      <list></list>
    </property>
    <property name="compileTimeDeps">
      <list>
        <value>core.Ext</value>
      </list>
    </property>
  </bean>
  <bean id="state.StateManager" class="jetbrains.mps.webr.javascript.runtime.jsDependencies.JsDependency">
    <property name="name">
      <value>state.StateManager</value>
    </property>
    <property name="urlGetter">
      <bean class="jetbrains.mps.webr.javascript.runtime.jsDependencies.ClasspathUrlGetter" autowire="byType">
        <property name="resourcePath">
          <value>state/StateManager.js</value>
        </property>
      </bean>
    </property>
    <property name="runTimeDeps">
      <list></list>
    </property>
    <property name="compileTimeDeps">
      <list>
        <value>core.Ext</value>
        <value>state.Provider</value>
      </list>
    </property>
  </bean>
</beans>
