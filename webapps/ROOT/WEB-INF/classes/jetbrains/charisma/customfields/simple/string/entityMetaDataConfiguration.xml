<beans>
  <bean id="jetbrains.charisma.customfields.simple.string.StringFieldValueMetaData" class="com.jetbrains.teamsys.dnq.database.EntityMetaDataImpl">
    <property name="versionMismatchIgnoredForWholeClass">
      <value>false</value>
    </property>
    <property name="initializer">
      <bean id="persistentClassInitializer" class="jetbrains.charisma.customfields.simple.string.StringFieldValueImpl"></bean>
    </property>
    <property name="superType">
      <value>FieldValue</value>
    </property>
    <property name="type">
      <value>StringFieldValue</value>
    </property>
    <property name="propertiesMetaData">
      <list>
        <bean class="com.jetbrains.teamsys.dnq.database.PropertyMetaDataImpl">
          <property name="name">
            <value>value</value>
          </property>
          <property name="type">
            <value>PRIMITIVE</value>
          </property>
        </bean>
      </list>
    </property>
    <property name="removeOrphan">
      <value>true</value>
    </property>
  </bean>
</beans>
