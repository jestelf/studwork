<beans>
  <bean id="jetbrains.charisma.ldap.persistence.LdapServerSettingsMetaData" class="com.jetbrains.teamsys.dnq.database.EntityMetaDataImpl">
    <property name="versionMismatchIgnoredForWholeClass">
      <value>false</value>
    </property>
    <property name="initializer">
      <bean id="persistentClassInitializer" class="jetbrains.charisma.ldap.persistence.LdapServerSettingsImpl"></bean>
    </property>
    <property name="type">
      <value>LdapServerSettings</value>
    </property>
    <property name="propertiesMetaData">
      <list>
        <bean class="com.jetbrains.teamsys.dnq.database.PropertyMetaDataImpl">
          <property name="name">
            <value>__ENUM_CONST_NAME__</value>
          </property>
          <property name="type">
            <value>PRIMITIVE</value>
          </property>
        </bean>
        <bean class="com.jetbrains.teamsys.dnq.database.PropertyMetaDataImpl">
          <property name="name">
            <value>enabled</value>
          </property>
          <property name="type">
            <value>PRIMITIVE</value>
          </property>
        </bean>
        <bean class="com.jetbrains.teamsys.dnq.database.PropertyMetaDataImpl">
          <property name="name">
            <value>formatDN</value>
          </property>
          <property name="type">
            <value>PRIMITIVE</value>
          </property>
        </bean>
        <bean class="com.jetbrains.teamsys.dnq.database.PropertyMetaDataImpl">
          <property name="name">
            <value>loginQuery</value>
          </property>
          <property name="type">
            <value>PRIMITIVE</value>
          </property>
        </bean>
        <bean class="com.jetbrains.teamsys.dnq.database.PropertyMetaDataImpl">
          <property name="name">
            <value>url</value>
          </property>
          <property name="type">
            <value>PRIMITIVE</value>
          </property>
        </bean>
      </list>
    </property>
    <property name="removeOrphan">
      <value>true</value>
    </property>
  </bean>
  <bean id="jetbrains.charisma.ldap.persistence.LdapUserDataMetaData" class="com.jetbrains.teamsys.dnq.database.EntityMetaDataImpl">
    <property name="versionMismatchIgnoredForWholeClass">
      <value>false</value>
    </property>
    <property name="initializer">
      <bean id="persistentClassInitializer" class="jetbrains.charisma.ldap.persistence.LdapUserDataImpl"></bean>
    </property>
    <property name="superType">
      <value>BaseUserData</value>
    </property>
    <property name="type">
      <value>LdapUserData</value>
    </property>
    <property name="propertiesMetaData">
      <list>
        <bean class="com.jetbrains.teamsys.dnq.database.PropertyMetaDataImpl">
          <property name="name">
            <value>login</value>
          </property>
          <property name="type">
            <value>PRIMITIVE</value>
          </property>
        </bean>
        <bean class="com.jetbrains.teamsys.dnq.database.PropertyMetaDataImpl">
          <property name="name">
            <value>user</value>
          </property>
          <property name="type">
            <value>PRIMITIVE</value>
          </property>
        </bean>
      </list>
    </property>
    <property name="associationEnds">
      <list>
        <ref bean="jetbrains.charisma.authentication.BaseUserData.user"/>
      </list>
    </property>
    <property name="removeOrphan">
      <value>true</value>
    </property>
  </bean>
</beans>
