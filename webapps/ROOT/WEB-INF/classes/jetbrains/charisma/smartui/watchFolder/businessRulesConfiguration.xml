  </bean>
  <bean id="IssueWatchRules_newIssue" class="jetbrains.charisma.smartui.watchFolder.IssueWatchRules_newIssue_Rule">
    <property name="rulePackage">
      <ref bean="IssueWatchRules"/>
    </property>
  </bean>
</beans>
