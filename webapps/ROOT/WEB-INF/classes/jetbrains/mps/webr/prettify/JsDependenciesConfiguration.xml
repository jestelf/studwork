<beans>
  <bean id="jetbrains.mps.webr.prettify.prettify" class="jetbrains.mps.webr.javascript.runtime.jsDependencies.JsDependency">
    <property name="name">
      <value>jetbrains.mps.webr.prettify.prettify</value>
    </property>
    <property name="urlGetter">
      <bean class="jetbrains.mps.webr.javascript.runtime.jsDependencies.ClasspathUrlGetter" autowire="byType">
        <property name="resourcePath">
          <value>prettify/prettify-min.js</value>
        </property>
      </bean>
    </property>
    <property name="runTimeDeps">
      <list></list>
    </property>
    <property name="compileTimeDeps">
      <list></list>
    </property>
  </bean>
</beans>
