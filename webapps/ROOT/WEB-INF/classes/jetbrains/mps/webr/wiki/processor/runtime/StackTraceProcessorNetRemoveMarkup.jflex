%type Void

Space = [ \t]+
SpaceLine = {Space}?\n
netExceptionFirstLink = ([:jletterdigit:]+ ".")* [:jletterdigit:]+":" ([^\n-]|([-][^\n>]))*(\n|"->")
netExceptionPrefix = {netExceptionFirstLink}([ \n\t]*("-"+">")?{netExceptionFirstLink})*
netExceptionStackTraceFirstPartElement = {Space}?"at"{Space}([a-zA-Z0-9_<>`]+".")+[a-zA-Z0-9_<>\[\],]+"(" ([^):])* ")"
netExceptionStackTraceSecondPartElement = ({Space}"in")~(":line ") [:digit:]+(" column "[:digit:]+)?
netExceptionStackTraceElement = {netExceptionStackTraceFirstPartElement}({netExceptionStackTraceSecondPartElement})?{SpaceLine}?
netSelectPart = "---" .* "---"{SpaceLine}?
netException = {netExceptionPrefix}?({netExceptionStackTraceElement})+({netSelectPart}([ \n\t]*{netExceptionPrefix})?{netExceptionStackTraceElement}*)*
netNewLine = \n
newline = \n

