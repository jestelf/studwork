  public void appendTraceElement(boolean noMarkup) {
    String inputText = this.getText().trim();
    if (!(noMarkup)) {
      {
        TBaseBuilderContext builderContext = this.builderContext;
        builderContext.append(this.StackTraceNettab);
      }
    } else {
      {
        TBaseBuilderContext builderContext = this.builderContext;
        builderContext.append("\t");
      }
    }
    int pos = inputText.indexOf(") in");
    pos++ ;
    if (pos == 0) {
      this.appendLeftPartOfStackTraceElement(inputText, noMarkup);
    } else {
      this.appendLeftPartOfStackTraceElement(inputText.substring(0, pos), noMarkup);
      StringTokenizer st = new StringTokenizer(inputText.substring(pos));
      {
        TBaseBuilderContext builderContext = this.builderContext;
        builderContext.append(" ");
        builderContext.append(this.keyword(st.nextToken(), noMarkup) + " ");
      }
      String pathAndLine = st.nextToken("").trim();
      int lineStart = pathAndLine.indexOf(":line");
      String sPath = this.getPath(pathAndLine.substring(0, lineStart));
      String sLine = "line";
      st = new StringTokenizer(pathAndLine.substring(lineStart + 6));
      int lineNum = Integer.parseInt(st.nextToken());
      String linkTag = "<a title=\"Open in IDE\" class=\"  dsLinkEnabled\" txt=\"" + sPath + "\" lne=\"" + lineNum + "\">";
      if (!(noMarkup)) {
        this.appendIdeLink(linkTag, sPath, noMarkup);
      }
      {
        TBaseBuilderContext builderContext = this.builderContext;
        builderContext.append(":" + this.keyword(sLine, noMarkup) + " ");
      }
      this.appendIdeLink(linkTag, "" + lineNum, noMarkup);
      if (st.hasMoreTokens()) {
        {
          TBaseBuilderContext builderContext = this.builderContext;
          builderContext.append(" ");
          builderContext.append(this.keyword(st.nextToken(), noMarkup));
          builderContext.append(" ");
        }
        this.appendIdeLink(linkTag, st.nextToken(), noMarkup);
      }
    }
    this.breakLine(noMarkup);
  }


  public static StackTraceProcessorNetRemoveMarkup create(String s) {
    if (s == null) {
      Reader reader = null;
      return new StackTraceProcessorNetRemoveMarkup(reader);
    } else {
      return new StackTraceProcessorNetRemoveMarkup(new TrailingCharStringReader(s, '\n'));
    }
  }
