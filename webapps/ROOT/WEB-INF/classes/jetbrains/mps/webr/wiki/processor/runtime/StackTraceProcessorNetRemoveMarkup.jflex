  public void appendSelectPart(String arg, boolean noMarkup) {
    arg = arg.substring(3, arg.length() - 3);
    if (!(noMarkup)) {
      {
        TBaseBuilderContext builderContext = this.builderContext;
        builderContext.append("--- <b>");
      }
      this.appendText(arg, noMarkup);
      {
        TBaseBuilderContext builderContext = this.builderContext;
        builderContext.append("</b> ---");
      }
    } else {
      this.appendText(arg, noMarkup);
    }
    this.breakLine(noMarkup);
  }

  public void appendLeftPartOfStackTraceElement(String inputText, boolean noMarkup) {
    String leftPart = inputText.trim();
    int posFirstSpace = leftPart.indexOf(" ");
    {
      TBaseBuilderContext builderContext = this.builderContext;
      builderContext.append(this.keyword(leftPart.substring(0, posFirstSpace), noMarkup) + " ");
    }
    if (!(noMarkup)) {
      {
        TBaseBuilderContext builderContext = this.builderContext;
        builderContext.append(HtmlStringUtil.html(leftPart.substring(posFirstSpace + 1)));
      }
    } else {
      {
        TBaseBuilderContext builderContext = this.builderContext;
        builderContext.append(leftPart.substring(posFirstSpace + 1));
      }
    }
  }

  public void appendIdeLink(String tag, String path, boolean noMarkup) {
    if (!(noMarkup)) {
      {
        TBaseBuilderContext builderContext = this.builderContext;
        builderContext.append(tag);
      }
      {
        TBaseBuilderContext builderContext = this.builderContext;
        builderContext.append(HtmlStringUtil.html(path));
