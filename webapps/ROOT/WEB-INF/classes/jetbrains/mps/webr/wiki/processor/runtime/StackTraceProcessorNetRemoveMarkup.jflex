        builderContext.append("\n");
      }
    } else {
      {
        TBaseBuilderContext builderContext = this.builderContext;
        builderContext.append("<br/>");
      }
    }
  }

  public void appendPrefix(boolean noMarkup) {
    String[] exceptionCascade = this.getText().split("-+>");
    boolean need = false;
    for (String except : exceptionCascade) {
      if (need) {
        this.breakLine(noMarkup);
        this.appendText("---> ", noMarkup);
      }
      String exc = except.trim();
      this.appendText(exc, noMarkup);
      need = true;
    }
    this.breakLine(noMarkup);
  }

  public String getPath(String arg) {
