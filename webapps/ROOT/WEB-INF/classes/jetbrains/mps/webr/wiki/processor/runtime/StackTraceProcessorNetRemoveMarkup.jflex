  private String StackTraceNetkeywordR = "</b>";
  private String StackTraceNetexcL = "";
  private String StackTraceNetexcR = "";
  private String StackTraceNettab = "&nbsp;";
  private int NewLinesSimplenewLineCount;

  public IWikiProcessor clone(String input) {
