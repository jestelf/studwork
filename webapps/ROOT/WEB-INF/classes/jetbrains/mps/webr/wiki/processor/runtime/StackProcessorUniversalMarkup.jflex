          } finally {
            this.text = null;
          }
}}
/* JavaCheck */
<ElementAnalyz> {
[a-zA-Z0-9_.]+".java:"[:digit:]+")"{SpaceLine}? {
          try {
            int position = this.getText().indexOf(':');
            int bracket = this.getText().indexOf(')');
            String cpath = this.getText().substring(0, position);
            String line = this.getText().substring(position + 1, bracket);
            this.appendilka(new String[]{cpath,line}, StackTokenType.JAVA_PATHLINE);
            this.appendBreak(this.getText());
            this.endState();
          } finally {
            this.text = null;
