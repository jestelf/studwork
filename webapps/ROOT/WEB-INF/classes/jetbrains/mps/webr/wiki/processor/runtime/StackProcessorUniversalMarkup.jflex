}}
/* Prefix */
<YYINITIAL> {
{HalfPrefix}({ExtSpace}{SpaceLine})? {
          try {
            String val = this.getText().trim();
            int position = val.indexOf(':');
            if (position != -1) {
              this.appendilka(new String[]{val.substring(0, position).trim(),val.substring(position + 1).trim()}, StackTokenType.EXCEPTION_CLASS);
            } else {
              this.appendilka(new String[]{val.trim(),null}, StackTokenType.EXCEPTION_CLASS);
            }
            this.appendBreak(this.getText());
            this.beginState(this.exceptionPrefix);
          } finally {
            this.text = null;
