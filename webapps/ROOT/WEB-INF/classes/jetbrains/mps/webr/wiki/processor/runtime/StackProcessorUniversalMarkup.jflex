          }
}}
/* NewLineEofIgnore */
<YYINITIAL> {
({newline})+ {
          try {
            //  just ignore, newlines at the end of input are not appended
          } finally {
            this.text = null;
          }
}}
/* Finish */
<YYINITIAL, exceptionPrefix, ElementAnalyz, NetFinish> {
. {
          this.builderContext.append(Character.toString(this.yycharat(0)));
