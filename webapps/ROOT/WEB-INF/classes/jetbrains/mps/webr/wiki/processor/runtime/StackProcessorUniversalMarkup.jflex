            }
            String path = this.getText().substring(0, position).trim();
            StringTokenizer st = new StringTokenizer(this.getText().substring(position + 1));
            List<String> lst = ListSequence.fromList(new ArrayList<String>());
            ListSequence.fromList(lst).addElement(path);
            while (st.hasMoreTokens()) {
              ListSequence.fromList(lst).addElement(st.nextToken());
            }
            this.appendilka(ListSequence.fromList(lst).toGenericArray(String.class), StackTokenType.NET_LINK);
            this.appendBreak(this.getText());
            this.endState();
          } finally {
