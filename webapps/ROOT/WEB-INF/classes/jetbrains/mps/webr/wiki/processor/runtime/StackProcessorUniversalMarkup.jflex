%type Void

KeyWord = [:jletter:]+
JavaId = [:jletter:][:jletterdigit:]*
NetAngleId = [0-9A-Za-z_<>`]+
NetBrackId = [0-9A-Za-z<>`\[\]]+
KeyExcWord = ("Failure"|"Exception"|"Error"|"Throwable")
ExceptionClass = ({NetAngleId}?".")+{NetAngleId}?{KeyExcWord}
HalfPrefix = {ExceptionClass}(":"([^\n-]|-+[^\n>])*)?
Prefix = {ExceptionClass}(":"([^\n-]|-*[^\n>])*("->"|\n)?)?
FullPrefix = {Prefix}+
Space = [\t ]+
ExtSpace = [\t\n ]*
SpaceLine = [\t ]*\n
Number = [:digit:]+
ElementSuffix = {KeyWord}([^()]+(":"{KeyWord})){Space}{Number}({Space}{KeyWord}{Space}{Number})?
TraceLeftPart = {Space}?{KeyWord}{Space}({NetAngleId}".")+{NetBrackId}"("
TraceElement = {Space}?{KeyWord}{Space}({NetAngleId}".")+{NetBrackId}"("[^)\n]*")"{Space}?{ElementSuffix}?\n?
Selector = {Space}?"---"~("---")
Cause = \n({Space})?{KeyWord}({Space}{KeyWord})+":".*
LineBreak = ({Cause}|{Selector})\n
MorePart = {Number}{Space}{KeyWord}.*\n?
Exc = {FullPrefix}?{TraceElement}+({LineBreak}({FullPrefix})?{TraceElement}*{MorePart}?)*
Exception = {LineBreak}?{FullPrefix}?{TraceElement}+{MorePart}?
newline = \n

%state exceptionPrefix, ElementAnalyz, NetFinish

