}}
/* CauseBreak */
<YYINITIAL> {
{Cause}{SpaceLine}? {
          try {
            String reasonKey = this.getText().substring(0, this.getText().indexOf(':')).trim();
            String reason = this.getText().substring(this.getText().indexOf(':') + 1).trim();
            this.appendilka(new String[]{reasonKey,reason}, StackTokenType.CAUSER);
