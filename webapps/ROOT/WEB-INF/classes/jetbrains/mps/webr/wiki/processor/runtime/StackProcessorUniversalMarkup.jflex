}}
/* TraceElementFirstPart */
<YYINITIAL, exceptionPrefix> {
{TraceLeftPart} {
          try {
            StringTokenizer st = new StringTokenizer(this.getText());
            String keyAt = st.nextToken();
            String meth = st.nextToken("(").trim();
            this.StrackTraceUniversalPartpath = this.extractPath(meth);
            this.appendilka(new String[]{keyAt,meth}, StackTokenType.ELEMENT_PREFIX);
            if (this.yystate() == this.exceptionPrefix) {
              this.endState();
            }
            this.beginState(this.ElementAnalyz);
          } finally {
            this.text = null;
