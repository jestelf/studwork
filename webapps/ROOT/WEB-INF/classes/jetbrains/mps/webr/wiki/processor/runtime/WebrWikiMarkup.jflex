/* CodeLineParser */
<YYINITIAL> {
{prefix}{netException} {
          try {
            int pos = 1;
            {
              TBaseBuilderContext builderContext = this.builderContext;
              builderContext.append(this.getText().substring(0, pos));
            }
            {
              TBaseBuilderContext builderContext = this.builderContext;
              builderContext.append("<span class=\"wiki javaExceptionFirstLine\">");
            }
            int suffix = 0;
            for (int i = this.getText().length() - 1 ; i >= 0 && (this.getText().charAt(i) == this.NetStackTracenewLine) ; i-- ) {
              suffix++ ;
            }
            String input = StringUtils.trim(this.getText().substring(pos, this.getText().length() - suffix));
            if (this.NetStackTracenoJS) {
              {
                TBaseBuilderContext builderContext = this.builderContext;
                builderContext.append(HtmlStringUtil.html(input));
              }
            } else {
              this.processNetStackTrace(input);
            }
            {
              TBaseBuilderContext builderContext = this.builderContext;
              builderContext.append("</span>");
            }
            for (int i = 0 ; i < suffix ; i++ ) {
              if (suffix == '\n') {
                {
                  TBaseBuilderContext builderContext = this.builderContext;
                  builderContext.append("<br/>");
                }
              }
            }
          } finally {
            this.text = null;
          }
}}
