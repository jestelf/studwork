            {
              TBaseBuilderContext builderContext = this.builderContext;
              builderContext.append("<span class=\"wiki javaExceptionFirstLine\">");
            }
            if (this.JavaStacktracenoJS) {
              {
                TBaseBuilderContext builderContext = this.builderContext;
