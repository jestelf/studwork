<beans>
  <bean id="adapter.ext-base" class="jetbrains.mps.webr.javascript.runtime.jsDependencies.JsDependency">
    <property name="name">
      <value>adapter.ext-base</value>
    </property>
    <property name="urlGetter">
      <bean class="jetbrains.mps.webr.javascript.runtime.jsDependencies.ClasspathUrlGetter" autowire="byType">
        <property name="resourcePath">
          <value>adapter/ext-base.js</value>
        </property>
      </bean>
    </property>
    <property name="runTimeDeps">
      <list></list>
    </property>
    <property name="compileTimeDeps">
      <list>
        <value>core.Ext</value>
      </list>
    </property>
  </bean>
</beans>
